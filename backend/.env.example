# MongoDB - for local Docker: use mongodb://mongo:27017
# For MongoDB Atlas: use mongodb+srv://USER:PASS@cluster.xxx.mongodb.net/taskflow_pro
MONGO_URL=mongodb://mongo:27017
DB_NAME=taskflow_pro

# JWT (required)
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256

# Optional - for email invites (leave empty for local dev)
# SENDGRID_API_KEY=
# SENDER_EMAIL=noreply@taskflow.pro

# Optional - CORS (defaults to * if not set)
# CORS_ORIGINS=*
